{
  "name": "@victor-software-house/pi-extension-manager",
  "version": "0.8.4",
  "description": "Interactive extension and package manager for Pi",
  "license": "MIT",
  "author": "Victor Software House",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/victor-software-house/pi-extension-manager.git"
  },
  "homepage": "https://github.com/victor-software-house/pi-extension-manager#readme",
  "bugs": {
    "url": "https://github.com/victor-software-house/pi-extension-manager/issues"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi-coding-agent",
    "extensions",
    "manager"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ],
    "image": "https://raw.githubusercontent.com/victor-software-house/pi-extension-manager/main/assets/package-preview.png"
  },
  "type": "module",
  "main": "./src/index.ts",
  "files": [
    "src/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "prepare": "lefthook install",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --passWithNoTests",
    "prepublishOnly": "pnpm run lint && pnpm run typecheck && pnpm test && pnpm run build"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": ">=0.75.0",
    "@earendil-works/pi-tui": ">=0.75.0"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": true
    },
    "@earendil-works/pi-tui": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@earendil-works/pi-coding-agent": "^0.75.0",
    "@earendil-works/pi-tui": "^0.75.0",
    "@types/node": "^22.13.10",
    "lefthook": "^2.1.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "packageManager": "pnpm@11.1.1"
}
